{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "DeadSpacePlugin.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build (Debug)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DeadSpacePlugin.csproj",
                "--configuration",
                "Debug",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "group": "build",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build (Release)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DeadSpacePlugin.csproj",
                "--configuration",
                "Release",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "group": "build",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build (FMT_PRO)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/DeadSpacePlugin.csproj",
                "--configuration",
                "FMT_PRO",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "group": "build",
            "presentation": {
                "reveal": "silent"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "copy-to-fmt (Debug)",
            "command": "powershell",
            "type": "shell",
            "args": [
                "-Command",
                "& { $src = '${workspaceFolder}/bin/Debug/net10.0/DeadSpacePlugin.dll'; $dst = Join-Path $env:FMT_PLUGINS_DIR 'DeadSpacePlugin.dll'; if (-not $env:FMT_PLUGINS_DIR) { Write-Error 'FMT_PLUGINS_DIR environment variable is not set. Set it to your FMT Plugins folder path.'; exit 1 }; Copy-Item -LiteralPath $src -Destination $dst -Force; Write-Host 'Copied to:' $dst }"
            ],
            "problemMatcher": [],
            "dependsOn": [
                "build (Debug)"
            ]
        },
        {
            "label": "copy-to-fmt (Release)",
            "command": "powershell",
            "type": "shell",
            "args": [
                "-Command",
                "& { $src = '${workspaceFolder}/bin/Release/net10.0/DeadSpacePlugin.dll'; $dst = Join-Path $env:FMT_PLUGINS_DIR 'DeadSpacePlugin.dll'; if (-not $env:FMT_PLUGINS_DIR) { Write-Error 'FMT_PLUGINS_DIR environment variable is not set. Set it to your FMT Plugins folder path.'; exit 1 }; Copy-Item -LiteralPath $src -Destination $dst -Force; Write-Host 'Copied to:' $dst }"
            ],
            "problemMatcher": [],
            "dependsOn": [
